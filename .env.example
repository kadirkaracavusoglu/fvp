# Sanity — proje açtıktan sonra buraya Project ID'yi yaz
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Supabase — form kayıtları (subscribers + contacts) buraya düşer
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# GoHighLevel — form/lead webhook'u
GHL_WEBHOOK_URL=

# --- Takip kimlikleri ---
# Boş bırakılan araç HİÇ yüklenmez. Bu bilinçli: site başka bir marka için
# klonlanırsa ve doldurulmazsa, veri yanlış hesaba gitmez — hiç gitmez.
# NEXT_PUBLIC_* build sırasında gömülür → Vercel'de de tanımlı olmalı,
# yoksa canlıda takip sessizce durur.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_FB_APP_ID=
